{
  "buildCommand": "cd frontend && npm i && npm run build",
  "outputDirectory": "frontend/dist",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/index.py": {
      "includeFiles": "backend/app/**",
      "memory": 512,
      "maxDuration": 30
    }
  }
}
